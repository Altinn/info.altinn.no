# Umbraco Delivery API base URL (without trailing /umbraco/...) used by the
# frontend at request time to fetch content. Per-env values live in wrangler.jsonc.
UMBRACO_API_URL=http://localhost:5000/

# Umbraco Delivery API key — sent as `Api-Key` header when fetching draft (preview)
# content. Must match Umbraco:CMS:DeliveryApi:ApiKey in the CMS appsettings.
UMBRACO_API_KEY=

# Headless preview shared secret — must match HeadlessPreview:PreviewSecret in
# the CMS appsettings. The middleware validates ?secret=<value> before flipping
# the request into preview mode (cookie + bypass cache + draft fetch).
PREVIEW_SECRET=

# Elasticsearch (search index)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=infoportal
