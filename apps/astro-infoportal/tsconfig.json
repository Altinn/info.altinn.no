{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "src",
    "src/declaration.d.ts",
    "**/*"
  ],
  "compilerOptions": {
    "paths": {
      "/*": [
        "./src/*"
      ],
      "@components/*": [
        "./src/Components/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@api/*": [
        "./src/api/*"
      ],
      "@constants/*": [
        "./src/Constants/*"
      ],
      "@services/*": [
        "./src/Services/*"
      ],
      "@models/*": [
        "./src/Models/*"
      ],
      "@transformers/*": [
        "./src/transformers/*"
      ],
      "@i18n/*": [
        "./src/i18n/*"
      ]
    },
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "target": "ESNext",
    "useDefineForClassFields": true,
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": false,
    "jsxImportSource": "react"
  }
}