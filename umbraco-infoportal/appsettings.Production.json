{
  "Serilog": {
    "WriteTo": [
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://otel-collector.monitoring.svc.cluster.local:4317",
          "Protocol": "Grpc",
          "ResourceAttributes": {
            "service.name": "infoportal"
          }
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Runtime": {
        "Mode": "Production"
      },
      "Hosting": {
        "Debug": false
      },
      "Global": {
        "UseHttps": false
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "HealthChecks": {
        "DisabledChecks": [
          {
            "Id": "E2048C48-21C5-4BE1-A80B-8062162DF124"
          }
        ]
      },
      "Storage": {
        "AzureBlob": {
          "Media": {
            "ConnectionString": "Will be set as environment variable",
            "ContainerName": "umbraco"
          }
        }
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "KeyVault": {
    "Enabled": true
  }
}
