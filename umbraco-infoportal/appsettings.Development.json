{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      },
      "BasicAuth": {
        "RedirectToLoginPage": true
      }
    }
  },
  "MicrosoftEntraId": {
    "ClientId": "YOUR_DEVELOPMENT_CLIENT_ID",
    "ClientSecret": "YOUR_DEVELOPMENT_CLIENT_SECRET",
    "TenantId": "YOUR_DEVELOPMENT_TENANT_ID"
  }
}
