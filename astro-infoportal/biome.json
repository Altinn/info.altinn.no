{
  "$schema": "https://biomejs.dev/schemas/2.1.3/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "off",
        "noExplicitAny": "off",
        "noEmptyInterface": "off"
      },
      "style": {
        "useTemplate": "off",
        "useSelfClosingElements": "off",
        "noUnusedTemplateLiteral": "off",
        "useImportType": "off"
      },
      "complexity": {
        "useLiteralKeys": "off",
        "noBannedTypes": "off",
        "noForEach": "off",
        "useOptionalChain": "off"
      },
      "a11y": {
        "useButtonType": "off",
        "useKeyWithClickEvents": "off",
        "noSvgWithoutTitle": "off",
        "useMediaCaption": "off",
        "useIframeTitle": "off",
        "useValidAnchor": "off",
        "noNoninteractiveElementToInteractiveRole": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "performance": {
        "noDynamicNamespaceImportAccess": "off"
      }
    }
  }
}