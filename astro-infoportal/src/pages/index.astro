---
import { fetchUmbracoContent, START_PAGE_EXPAND } from '@api/umbraco/client';
import AstroSiteLayout from '@layouts/AstroSiteLayout.astro';
import { JSONTransformer } from '@transformers/JSONTransformer';
import { getGlobalData } from '@constants/globalData';
import { pageCacheControl } from '@constants/cache';
import { resolveEnvironment } from '@api/altinn/environments';
import type { Locale } from '@i18n/index';

const locale = (Astro.currentLocale || "nb") as Locale;
const altinnEndpoints = resolveEnvironment(Astro.url.hostname);

let umbracoPageData: any = null;

// Fetch the correct Umbraco path for the locale
const umbracoPath = locale === "en" ? "/en/" : "/";
const [pageResult] = await Promise.allSettled([
  // expand the banner and consentBanner pickers so the view models get the node's properties (see fetchUmbracoStartPage)
  fetchUmbracoContent(umbracoPath, locale, START_PAGE_EXPAND),
]);

if (pageResult.status === 'rejected') {
  console.error("Error fetching start page data from Umbraco:", pageResult.reason);
  return Astro.redirect("/404");
}
umbracoPageData = pageResult.value;

const searchPageUrl = locale === "en"
  ? "/en/search/"
  : locale === "nn"
    ? "/nn/sok/"
    : "/sok/";
const contentLocale: Locale =
  umbracoPageData?.cultures && umbracoPageData.cultures[locale]
    ? locale
    : "nb";
const globalData: any = getGlobalData(
  locale,
  searchPageUrl,
  altinnEndpoints,
  umbracoPageData?.cultures,
  umbracoPageData,
  umbracoPageData?.contentType,
  undefined,
  contentLocale,
);

const pageData = await new JSONTransformer().Transform(umbracoPageData, globalData);

Astro.response.headers.set("Cache-Control", pageCacheControl(Astro.url.hostname));
---

<AstroSiteLayout pageData={pageData} />
