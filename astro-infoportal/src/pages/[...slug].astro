---

import { fetchUmbracoContent } from '../api/umbraco/client';
import ReactView from '../layouts/ReactView.astro';
import { JSONTransformer } from '../transformers/JSONTransformer';

const path = Astro.url.pathname;

let umbracoPageData;
try {
  umbracoPageData = await fetchUmbracoContent(path);
} catch (e) {
  Astro.redirect("/404");
}

const pageData = new JSONTransformer().Transform(umbracoPageData);

Astro.response.headers.set("Cache-Control", "public, max-age=0, s-maxage=86400");
---

<ReactView {pageData} />
