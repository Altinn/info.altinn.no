---

import { fetchUmbracoContentWithLocaleFallback, fetchUmbracoRedirect, fetchUmbracoErrorPage, fetchUmbracoStartPage, fetchUmbracoMedia, START_PAGE_EXPAND } from '@api/umbraco/client';
import AstroSiteLayout from '@layouts/AstroSiteLayout.astro';
import { JSONTransformer } from '@transformers/JSONTransformer';
import { getGlobalData } from '@constants/globalData';
import { pageCacheControl } from '@constants/cache';
import { buildMetadata } from '@constants/metadata';
import { resolveEnvironment } from '@api/altinn/environments';
import type { Locale } from '@i18n/index';


let path = Astro.url.pathname;
const search = Astro.url.search;
const locale = (Astro.currentLocale || "nb") as Locale;
const altinnEndpoints = resolveEnvironment(Astro.url.hostname);
const isNorwegianStartRoot = /^\/(no|nb)\/?$/.test(path);

// Ignore internal Vite/framework paths
if (
  path === '/favicon.ico' ||
  path.startsWith('/@vite/') ||
  path.startsWith('/@react-refresh') ||
  path.startsWith('/@id/') ||
  path.startsWith('/@fs/')
) {
  return new Response(null, { status: 404 });
}

if (path.startsWith("/Pages/") || path.startsWith("/pages/")) {
  const altinn2Url = "https://altinn.no" + path + search;
  return Astro.redirect(altinn2Url, 301);
}

/* Temporary fix as some links starting with /EPiServer/CMS/Content were not converted correctly during import */
const legacyInternalUrlPrefix = "/EPiServer/CMS/Content";
if (path.startsWith(legacyInternalUrlPrefix)) {
  let actualUrl = Astro.url.href;
  actualUrl = actualUrl.replace(legacyInternalUrlPrefix, "");
  actualUrl = actualUrl.substring(0, actualUrl.indexOf(","));
  return Astro.redirect(actualUrl, 301);
}

if (path.startsWith("/media/") || path.startsWith("/contentassets/") || path.startsWith("/publicassets/")) {
   const bytes = await fetchUmbracoMedia(path + search);
   return new Response(bytes);
 }

if (path.startsWith('/api/') || path.match(/\.[a-zA-Z0-9]+$/)) {
  return new Response(null, { status: 404 });
}

const redirectTarget = await fetchUmbracoRedirect(path);
if (redirectTarget && redirectTarget !== path) {
  const redirectUrl = new URL(redirectTarget, Astro.url);
  redirectUrl.search = Astro.url.search;
  return Astro.redirect(redirectUrl.toString(), 302);
}

// On a locale-root URL the requested page IS the startPage — reuse the fetch.
const isLocaleRoot = isNorwegianStartRoot || /^\/(nn|en)\/?$/.test(path);
const umbracoPath = isNorwegianStartRoot ? "/" : path;

// On a locale root the page IS the startPage — expand the banner picker so buildBanner gets it.
const pagePromise = fetchUmbracoContentWithLocaleFallback(
  umbracoPath,
  locale,
  isLocaleRoot ? START_PAGE_EXPAND : undefined,
);
const startPagePromise = isLocaleRoot ? pagePromise : fetchUmbracoStartPage(locale);

const [pageResult, startPageResult] = await Promise.allSettled([
  pagePromise,
  startPagePromise,
]);


let umbracoPageData;
let isError = false;

if (pageResult.status === 'rejected') {
  console.error("Error fetching page data from Umbraco:", pageResult.reason);
  umbracoPageData = await fetchUmbracoErrorPage(locale).catch(() => null);
  isError = true;
} else {
  umbracoPageData = pageResult.value;
}

const startPageData = startPageResult.status === 'fulfilled' ? startPageResult.value : null;

// When the request URL doesn't match the page's canonical path for the requested
// locale (e.g. /en/skjemaoversikt/... served via the NB-path fallback even though
// the page has an EN variant at /en/forms-overview/...), redirect so the URL bar
// and rendered content agree.

if (!isError && !isLocaleRoot) {
  const canonicalPath = umbracoPageData?.cultures?.[locale]?.path;
  const withSlash = (p: string) => (p.endsWith("/") ? p : `${p}/`);
  if (canonicalPath && withSlash(canonicalPath) !== withSlash(Astro.url.pathname)) {
    const canonicalUrl = new URL(canonicalPath, Astro.url);
    canonicalUrl.search = Astro.url.search;
    return Astro.redirect(canonicalUrl.toString(), 301);
  }
}

// If the requested locale isn't among the page's variants, Umbraco's Delivery API
// fell back to nb (see fetchUmbracoContentWithLocaleFallback). Downstream content
// fetches (children/ancestors/related) must use the effective culture, or they'll
// return empty for NB-only content. UI translations still use the requested locale.
const contentLocale: Locale =
  umbracoPageData?.cultures && umbracoPageData.cultures[locale]
    ? locale
    : "nb";

let globalData: any = getGlobalData(locale, "/sok/", altinnEndpoints, umbracoPageData?.cultures, startPageData, umbracoPageData?.contentType, path, contentLocale);
globalData = {
  ...globalData,
  startPageData,
  query: Object.fromEntries(Astro.url.searchParams.entries()),
  referer: Astro.request.headers.get("referer") || undefined,
};

const pageData = await new JSONTransformer().Transform(umbracoPageData, globalData);
const metadata = {
  // Drive <html lang> from the effective content language, not the URL locale:
  // an NB-only page served at /en/ falls back to nb content, so lang must be nb
  // to match the actual text a screen reader reads (issue #494 follow-up).
  ...buildMetadata(umbracoPageData, contentLocale),
  ...(isLocaleRoot ? { title: "Altinn - Start" } : {}),
};

if (isError) {
  Astro.response.status = 404;
}
Astro.response.headers.set("Cache-Control", pageCacheControl(Astro.url.hostname));
---

<AstroSiteLayout pageData={pageData} {...metadata} />
