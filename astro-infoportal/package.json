    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "lint-staged": "^16.2.6",
    "patch-package": "^8.0.1",
    "postcss-loader": "^8.2.0",
    "postcss-preset-env": "^10.4.0",
    "prettier": "^3.5.3",
    "rspack-manifest-plugin": "^5.1.0",
    "safe-stable-stringify": "2.5.0",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.6",
    "storybook": "^9.1.1",
