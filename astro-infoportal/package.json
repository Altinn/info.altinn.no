{
  "name": "astro-infoportal",
  "version": "0.0.1",
  "scripts": {
    "preview": "astro preview",
    "astro": "astro",
    "clean": "node -e \"require('fs').rmSync('./public/assets/generated', {recursive: true, force: true})\"",
    "build": "npm run clean && cross-env rspack --env config=prod && astro build",
    "dev": "cross-env rspack --env config=dev && astro dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@altinn/altinn-components": "^0.54.3",
